# Credenciales OAuth 2.0 de Google Cloud para YouTube Data API v3.
# Deben venir de una app tipo "Desktop app".
# Puedes usar directamente el JSON descargado desde Google Cloud:
YOUTUBE_CLIENT_SECRETS_FILE=

# O, alternativamente, copiar aqui el client_id y client_secret de ese JSON.
YOUTUBE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_google_oauth_client_secret

# Archivo local donde se guardara el token OAuth reutilizable.
YOUTUBE_TOKEN_FILE=out/youtube_upload/token.json

# Si ya tienes playlists creadas, coloca sus IDs aqui.
# Si se dejan vacias y el script lo permite, podra crearlas automaticamente.
YOUTUBE_PRODUCT_PLAYLIST_ID=
YOUTUBE_SOLUTION_PLAYLIST_ID=

# Titulos a usar si hay que crear las playlists automaticamente.
YOUTUBE_PRODUCT_PLAYLIST_TITLE=Planview Product Demos
YOUTUBE_SOLUTION_PLAYLIST_TITLE=Planview Solution Demos
YOUTUBE_PLAYLIST_PRIVACY_STATUS=unlisted

# Configuracion por defecto de los videos subidos.
YOUTUBE_VIDEO_PRIVACY_STATUS=unlisted
YOUTUBE_VIDEO_CATEGORY_ID=28
YOUTUBE_NOTIFY_SUBSCRIBERS=false
YOUTUBE_MADE_FOR_KIDS=false
YOUTUBE_CONTAINS_SYNTHETIC_MEDIA=false
YOUTUBE_HAS_PAID_PRODUCT_PLACEMENT=false

# Si es true, el script podra crear playlists cuando falten los IDs.
YOUTUBE_CREATE_PLAYLISTS_IF_MISSING=true

# Presupuesto diario de cuota API a respetar antes de detenerse.
YOUTUBE_DAILY_QUOTA_BUDGET=10000
